# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key
CLERK_SECRET_KEY=your_clerk_secret_key
# Setting CLERK_JWT_KEY enables server-side session-token verification without
# round-tripping to Clerk's BAPI on every request (eliminates cold-start 504 risk).
# Format: RSA public key PEM. Recommended on Vercel production.
CLERK_JWT_KEY=

# OpenAI — chatAboutDeal, plus the realtime voice platform (buddy-voice-gateway).
# The gateway (a separate Fly.io service, see buddy-voice-gateway/) needs its
# own copy of OPENAI_API_KEY set as a Fly secret — it does not read this file.
OPENAI_API_KEY=sk-...
# OPENAI_REALTIME_MODEL tracks the flagship Realtime model. Defaults to
# gpt-realtime in code if unset — override only to pin/test a different one.
# OPENAI_REALTIME_MODEL=gpt-realtime
# Voice used for the banker credit-interview session (default: marin).
# OPENAI_REALTIME_VOICE=marin
# Voice used for the anonymous brokerage borrower session (default: cedar).
# OPENAI_REALTIME_VOICE_BORROWER=cedar

# Buddy builder observer (build-mode only)
BUDDY_BUILDER_MODE=1
RESEND_API_KEY=


# Mistral OCR (deprecated/disabled)
# MISTRAL_API_KEY=
# USE_MISTRAL_OCR=false

# ─── Google Cloud Platform ─────────────────────────────────────────────────
# GCP project
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# Local dev: point to service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=
# Legacy inline JSON (prefer ADC or WIF instead)
# GOOGLE_APPLICATION_CREDENTIALS_JSON=

# ─── Vercel WIF (Workload Identity Federation) ────────────────────────────
# On Vercel, auth uses OIDC → WIF → SA impersonation. No JSON keys needed.
# GCP_WIF_PROVIDER is canonical. GCP_WORKLOAD_IDENTITY_PROVIDER is an alias.
GCP_WIF_PROVIDER=
# OR set split vars:
# GCP_PROJECT_NUMBER=
# GCP_WORKLOAD_IDENTITY_POOL_ID=
# GCP_WORKLOAD_IDENTITY_POOL_PROVIDER_ID=
GCP_SERVICE_ACCOUNT_EMAIL=

# ─── GCS Storage ──────────────────────────────────────────────────────────
DOC_STORE=supabase
GCS_BUCKET=
# GCS_UPLOAD_PREFIX=deals
# GCS_SIGN_TTL_SECONDS=900
# GCS_STRICT_SIGNING=0

# ─── Gemini OCR (Vertex AI) ──────────────────────────────────────────────
GEMINI_SERVICE_ACCOUNT_JSON=
USE_GEMINI_OCR=true
# GEMINI_OCR_MODEL is auto-selected by the gatekeeper — see
# src/lib/gatekeeper/geminiClassifier.ts for the current default string.
# Override only for experiments; do not hardcode a Gemini version here
# (the production default tracks the current Flash model and evolves).
# GEMINI_OCR_MODEL=

# (Optional) If you still use other Google APIs elsewhere
GOOGLE_API_KEY=

# Twilio SMS (for borrower portal links)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+15551234567

# App URL (for generating portal links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron protection (required for automated reminders)
CRON_SECRET=your_random_secret_change_this_to_something_long_and_random

# Observability (optional)
# Create a Sentry project and set these in Vercel (Project → Settings → Environment Variables)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# OpenTelemetry + Honeycomb (optional)
# To enable tracing, set either:
# - HONEYCOMB_API_KEY + HONEYCOMB_DATASET, OR
# - OTEL_EXPORTER_OTLP_ENDPOINT (+ OTEL_EXPORTER_OTLP_HEADERS)
#
# Recommended for Honeycomb OTLP/HTTP:
# OTEL_EXPORTER_OTLP_ENDPOINT=https://api.honeycomb.io/v1/traces
# OTEL_EXPORTER_OTLP_HEADERS=x-honeycomb-team=YOUR_KEY,x-honeycomb-dataset=YOUR_DATASET
HONEYCOMB_API_KEY=
HONEYCOMB_DATASET=
OTEL_SERVICE_NAME=buddy-the-underwriter
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=



# Public base URL for Twilio webhook signature verification
PUBLIC_BASE_URL=https://buddy-the-underwriter.vercel.app

# Buddy (persistent guide)
NEXT_PUBLIC_BUDDY_OBSERVER_MODE=0
NEXT_PUBLIC_BUDDY_DEFAULT_OPEN=0
NEXT_PUBLIC_BUDDY_ROLE=banker

# Buddy Voice A/B (A or B)
NEXT_PUBLIC_BUDDY_VOICE_VARIANT=A

# Shadow brain (Gemini) - server only
# GEMINI_MODEL tracks the current Flash model; canonical strings live in
# src/lib/ai/models.ts. Update when a new Gemini Flash generation lands.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview

# (TWILIO block above at ~line 62 — dedupe Phase 84 T-09. Used for both
#  borrower portal links and nudges. No second copy required.)

# ═══════════════════════════════════════════════════════════════════════════
# MCP / Pulse / Omega env vars — FIVE distinct subsystems, read carefully:
#
#   BUDDY_MCP_*         — inbound (Buddy exposes itself as an MCP server
#                         for Claude Desktop) — see src/lib/mcp/server.ts
#   OMEGA_MCP_*         — outbound (Buddy → Omega Prime advisory invocation)
#                         — see src/lib/omega/invokeOmega.ts
#   PULSE_MCP_*         — outbound, Next.js side (Buddy → Pulse MCP tools)
#                         — see src/lib/pulseMcp/config.ts +
#                         src/app/api/pulse/ingest/route.ts
#                         NOTE: the worker (Cloud Run) uses `PULSE_MCP_KEY`
#                         instead of `PULSE_MCP_API_KEY` — intentional split,
#                         enforced by
#                         src/lib/pulseMcp/__tests__/connection.test.ts
#   PULSE_BUDDY_INGEST_URL + PULSE_INGEST_TOKEN — telemetry forwarder
#                         (Bearer-authed direct HTTPS to Cloud Run,
#                          src/lib/pulse/forwardLedgerCore.ts)
#   PULSE_BUDDY_INGEST_SECRET — HMAC receiver for signed inbound events
#                         (src/app/api/pulse/ingest/route.ts)
# ═══════════════════════════════════════════════════════════════════════════

# ─── Omega Prime MCP (outbound advisory invocation) ────────────────────────
# Every Omega advisory call routes through src/lib/omega/invokeOmega.ts.
# JSON-RPC 2.0 POST to OMEGA_MCP_URL with Bearer auth.
# Set OMEGA_MCP_ENABLED=1 to activate; OMEGA_MCP_KILL_SWITCH=1 to force-disable.
OMEGA_MCP_ENABLED=0
OMEGA_MCP_KILL_SWITCH=0
OMEGA_MCP_URL=
OMEGA_MCP_API_KEY=
OMEGA_MCP_TIMEOUT_MS=5000

# ─── Pulse MCP (outbound, Next.js side) ────────────────────────────────────
# Buddy calls Pulse MCP tools for context/memory/decisions.
# Canonical URL is https://pulse-mcp-651478110010.us-central1.run.app/sse.
PULSE_MCP_ENABLED=false
PULSE_MCP_URL=https://pulse-mcp-651478110010.us-central1.run.app/sse
PULSE_MCP_API_KEY=
PULSE_MCP_TIMEOUT_MS=3000
PULSE_MCP_STRICT=false

# ─── Pulse telemetry forwarder (Next.js → Cloud Run direct, Bearer-authed) ─
# See src/lib/pulse/forwardLedgerCore.ts.
# Distinct from PULSE_BUDDY_INGEST_SECRET below — this is the Bearer-authed
# outbound forwarder; that is the HMAC-authed inbound receiver.
PULSE_TELEMETRY_ENABLED=false
PULSE_INGEST_TOKEN=

# ─── Pulse Observer Events (HMAC-signed inbound receiver) ──────────────────
# src/app/api/pulse/ingest/route.ts verifies HMAC on inbound signed events
# and forwards to the Pulse MCP server (PULSE_MCP_URL above).
PULSE_BUDDY_INGEST_URL=https://pulse-mcp-651478110010.us-central1.run.app/ingest/buddy
PULSE_BUDDY_INGEST_SECRET=

# Buddy identity (optional, auto-detected from Vercel env)
# BUDDY_ENV=dev
# BUDDY_RELEASE=

# Buddy MCP Server (for Claude Desktop integration)
# API key for authenticating MCP requests to /api/mcp
BUDDY_MCP_API_KEY=your_random_secret_key_here

# ─── Plaid (ARC-00 SPEC S2) ──────────────────────────────────────────────
# Soft bank-transaction data only (balances, transactions, statements) —
# no credit-bureau data. Sandbox in dev; production credentials gated
# behind a separate env. Multi-tenant Plaid (per-bank credentials) is
# deferred to v2. See src/lib/integrations/plaid/.
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_WEBHOOK_URL=https://buddytheunderwriter.com/api/webhooks/plaid
# 32-byte key, base64-encoded. Generate with: openssl rand -base64 32
PLAID_ACCESS_TOKEN_ENCRYPTION_KEY=

# ─── Secure PII intake (Phase 56B) ────────────────────────────────────────
# Encrypts banker-entered full SSN/TIN before storing in deal_pii_records
# (src/lib/builder/secure/securePiiIntake.ts). Builder sections only ever
# read back last4 + presence flags — the full value is never returned to
# a client after submission. REQUIRED in any environment where the PII
# intake form is reachable: with this unset (or under 16 chars),
# storeSecurePii fails closed and refuses to store anything rather than
# falling back to an insecure encoding. BUDDY_PII_KEY is accepted as a
# legacy alias if already set under that name.
# 32+ char symmetric key. Generate with: openssl rand -base64 32
PII_ENCRYPTION_KEY=

# ─── Didit IAL2-equivalent identity verification (ARC-00 SPEC S3) ────────
# Required before any SBA form can be e-signed (SOP 50 10 8 Appendix 10).
# Replaces Persona (2026-07-15) — see
# docs/build-logs/ARC00_VENDOR_PROVISIONING_CHECKLIST.md item 2.
# See src/lib/identity/kyc/.
DIDIT_API_KEY=
DIDIT_WORKFLOW_ID=
DIDIT_WEBHOOK_SECRET_KEY=

# ─── SignWell e-signature (ARC-00 SPEC S3) ───────────────────────────────
# Hosted API, no infrastructure to run — replaces the self-hosted DocuSeal
# plan (2026-07-15; DocuSeal was never deployed) — see
# docs/build-logs/ARC00_VENDOR_PROVISIONING_CHECKLIST.md item 3.
# See src/lib/esign/signwell/.
SIGNWELL_API_KEY=
SIGNWELL_TEST_MODE=true
# From the webhook's own Create/List Webhook response, NOT the API key —
# it's the HMAC key SignWell uses to sign event payloads.
SIGNWELL_WEBHOOK_ID=
# NOTE: no FORM_ infix — src/lib/esign/signwell/service.ts reads these
# exact names (strips "FORM_" from the internal form code before building
# the env var name), same convention DocuSeal used.
SIGNWELL_TEMPLATE_1919=
SIGNWELL_TEMPLATE_413=

# ─── CAIVRS federal debt screening (ARC-00 SPEC S4) ──────────────────────
# Global/env-scoped today, not per-bank — see src/lib/integrations/caivrs/client.ts
# for the known multi-tenant gap (spec wanted banks.settings.caivrs_credentials;
# that column didn't exist at build time).
CAIVRS_API_BASE=
CAIVRS_AUTH_USERNAME=
CAIVRS_AUTH_PASSWORD=

# ─── SAM.gov exclusion list check (ARC-00 SPEC S4) ───────────────────────
# See src/lib/integrations/samGov/client.ts. Optional — works without a key
# but gets rate-limited (429) at low quota.
SAM_GOV_API_KEY=

# ─── Credit bureau soft pull (ARC-00 SPEC S4) ────────────────────────────
# Vendor-agnostic wrapper — see src/lib/integrations/creditBureau/client.ts.
# CREDIT_BUREAU_VENDOR defaults to plaid_check if unset; that default was
# picked by the build executor without a stakeholder confirmation round-trip.
CREDIT_BUREAU_VENDOR=plaid_check
CREDIT_BUREAU_API_BASE_URL=
CREDIT_BUREAU_API_KEY=

# ─── IRS transcript vendor for Form 4506-C (ARC-00 SPEC S4) ──────────────
# Vendor-agnostic — see src/lib/integrations/irsTranscripts/client.ts.
# IRS_TRANSCRIPT_VENDOR accepts irs_direct | ncs | idology | wolters_kluwer,
# defaults to ncs. irs_direct requires Designated User auth (30+ day
# provisioning lead time) — prefer ncs or idology.
IRS_TRANSCRIPT_VENDOR=ncs
IRS_VENDOR_BASE_URL=
IRS_VENDOR_API_KEY=

# ─── SBA E-Tran (ARC-00 SPEC S5) ──────────────────────────────────────────
# Endpoint URLs are global; actual per-bank mutual-TLS certs are NOT env
# vars — they're uploaded via the bank-admin credential panel
# (/banks/[bankId]/templates → "SBA Integration Settings") and stored
# encrypted in bank_etran_credentials. See src/lib/etran/.
SBA_ETRAN_SANDBOX_ENDPOINT=
SBA_ETRAN_PROD_ENDPOINT=
# 32+ char symmetric key used to encrypt/decrypt stored client certs — this
# one IS a real secret to generate and set, independent of any vendor cert.
ETRAN_CRED_ENCRYPTION_KEY=
